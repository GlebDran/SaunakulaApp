<?xml version="1.0" encoding="utf-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SaunakulaApp.Views"
    x:Class="SaunakulaApp.AppShell"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="#FFFFFF"
    Shell.TabBarForegroundColor="#5A7C5E"
    Shell.TabBarUnselectedColor="#7A8A7D"
    Shell.TabBarTitleColor="#5A7C5E">

    <!-- Splash — без таббара -->
    <ShellContent
        Route="SplashPage"
        Shell.TabBarIsVisible="False"
        ContentTemplate="{DataTemplate views:SplashPage}"/>

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="icon_home.png"
            Route="HomePage"
            ContentTemplate="{DataTemplate views:HomePage}"/>

        <ShellContent
            Title="Hinnad"
            Icon="icon_pricing.png"
            Route="PricingPage"
            ContentTemplate="{DataTemplate views:PricingPage}"/>

        <ShellContent
            Title="Broneerimine"
            Icon="icon_calendar.png"
            Route="BookingsPage"
            ContentTemplate="{DataTemplate views:BookingsPage}"/>

        <ShellContent
            Title="Profiil"
            Icon="icon_profile.png"
            Route="ProfilePage"
            ContentTemplate="{DataTemplate views:ProfilePage}"/>
    </TabBar>

</Shell>
