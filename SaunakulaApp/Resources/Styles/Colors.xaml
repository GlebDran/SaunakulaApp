<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary palette (forest green from Figma) -->
    <Color x:Key="Primary">#5A7C5E</Color>
    <Color x:Key="PrimaryLight">#8BA888</Color>
    <Color x:Key="PrimaryExtraLight">#E8EDE7</Color>

    <!-- Backgrounds -->
    <Color x:Key="Background">#FAFAF8</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="SecondaryBackground">#E8EDE7</Color>
    <Color x:Key="MutedBackground">#F5F5F3</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#2D3B2F</Color>
    <Color x:Key="TextSecondary">#7A8A7D</Color>

    <!-- Accent -->
    <Color x:Key="Destructive">#C94D4D</Color>
    <Color x:Key="StarColor">#F59E0B</Color>
    <Color x:Key="Border">#E8EDE7</Color>

    <!-- Dark theme colors -->
    <Color x:Key="DarkBackground">#1A2420</Color>
    <Color x:Key="DarkCard">#2D3B2F</Color>
    <Color x:Key="DarkPrimary">#8BA888</Color>
    <Color x:Key="DarkText">#E8EDE7</Color>
    <Color x:Key="DarkTextSecondary">#A0B09D</Color>

</ResourceDictionary>