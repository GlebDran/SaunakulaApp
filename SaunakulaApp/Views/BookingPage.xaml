<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SaunakulaApp.Views.BookingPage"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12"
                      Padding="20,52,20,20"
                      BackgroundColor="{StaticResource CardBackground}">
                    <Frame WidthRequest="40" HeightRequest="40"
                           CornerRadius="20"
                           BackgroundColor="{StaticResource SecondaryBackground}"
                           BorderColor="Transparent"
                           Padding="0" HasShadow="False">
                        <Label Text="‹" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Back_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Frame>
                    <Label x:Name="BookingTitleLabel"
                           Text="Broneeri"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalOptions="Center"/>
                </Grid>

                <VerticalStackLayout Padding="20" Spacing="24">

                    <!-- House Card -->
                    <Frame Style="{StaticResource Card}" Padding="0">
                        <Grid ColumnDefinitions="100,*">
                            <Image x:Name="HouseImage"
                                   Aspect="AspectFill"
                                   HeightRequest="100" WidthRequest="100"/>
                            <VerticalStackLayout Grid.Column="1"
                                                 Padding="14,12" Spacing="4"
                                                 VerticalOptions="Center">
                                <Label x:Name="HouseTitleLabel"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="Saue vald, Harjumaa"
                                       Style="{StaticResource MutedLabel}" FontSize="12"/>
                                <Label x:Name="HousePriceLabel"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       Margin="0,4,0,0"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <!-- VIP Banner -->
                    <VerticalStackLayout x:Name="VipBannerView" IsVisible="False">
                        <Frame CornerRadius="14" Padding="14,12"
                               BorderColor="Transparent" HasShadow="False">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#B8860B" Offset="0"/>
                                    <GradientStop Color="#FFD700" Offset="1"/>
                                </LinearGradientBrush>
                            </Frame.Background>
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Label Text="👑" FontSize="18" VerticalOptions="Center"/>
                                <Label x:Name="VipBannerLabel"
                                       Text="VIP: Viht tasuta!"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="#2D2000"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Your Trip -->
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="TripLabel" Text="Sinu reis"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>

                        <!-- Check-in -->
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="CheckInLabel" Text="Saabumine"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Frame CornerRadius="14"
                                   BackgroundColor="{StaticResource MutedBackground}"
                                   BorderColor="Transparent" Padding="16,8" HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Text="📅" FontSize="18" VerticalOptions="Center"/>
                                    <DatePicker x:Name="CheckInPicker"
                                                Grid.Column="1"
                                                MinimumDate="{x:Static sys:DateTime.Today}"
                                                Format="dd.MM.yyyy"
                                                TextColor="{StaticResource TextPrimary}"
                                                BackgroundColor="Transparent"
                                                DateSelected="DatePicker_DateSelected"/>
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Check-out -->
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="CheckOutLabel" Text="Lahkumine"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Frame CornerRadius="14"
                                   BackgroundColor="{StaticResource MutedBackground}"
                                   BorderColor="Transparent" Padding="16,8" HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                    <Label Text="📅" FontSize="18" VerticalOptions="Center"/>
                                    <DatePicker x:Name="CheckOutPicker"
                                                Grid.Column="1"
                                                MinimumDate="{x:Static sys:DateTime.Today}"
                                                Format="dd.MM.yyyy"
                                                TextColor="{StaticResource TextPrimary}"
                                                BackgroundColor="Transparent"
                                                DateSelected="DatePicker_DateSelected"/>
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Guests -->
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="GuestsHeaderLabel" Text="Külaliste arv"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Frame CornerRadius="14"
                                   BackgroundColor="{StaticResource MutedBackground}"
                                   BorderColor="Transparent" Padding="16,12" HasShadow="False">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                    <Label Text="👥" FontSize="18" VerticalOptions="Center"/>
                                    <Label x:Name="GuestsLabel" Grid.Column="1"
                                           Text="2 külalist" FontSize="15"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center"/>
                                    <Frame Grid.Column="2"
                                           WidthRequest="36" HeightRequest="36" CornerRadius="18"
                                           BackgroundColor="{StaticResource CardBackground}"
                                           BorderColor="{StaticResource Border}"
                                           Padding="0" HasShadow="False">
                                        <Label Text="−" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               TextColor="{StaticResource TextPrimary}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="DecreaseGuests_Tapped"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Frame>
                                    <Frame Grid.Column="3"
                                           WidthRequest="36" HeightRequest="36" CornerRadius="18"
                                           BackgroundColor="{StaticResource Primary}"
                                           BorderColor="Transparent"
                                           Padding="0" HasShadow="False">
                                        <Label Text="+" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               TextColor="White">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="IncreaseGuests_Tapped"/>
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Frame>
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Notes -->
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="NotesLabel" Text="Lisainfo (vabatahtlik)"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <Frame CornerRadius="14"
                                   BackgroundColor="{StaticResource MutedBackground}"
                                   BorderColor="Transparent" Padding="16,12" HasShadow="False">
                                <Editor x:Name="NotesEditor"
                                        Placeholder="Toitlustus, erisoovid..."
                                        HeightRequest="80"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextPrimary}"
                                        PlaceholderColor="{StaticResource TextSecondary}"/>
                            </Frame>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Addons -->
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="AddonsHeaderLabel" Text="Lisateenused"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <CollectionView x:Name="AddonsView">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Style="{StaticResource Card}"
                                           Padding="12,10" Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="36,*,Auto,Auto" ColumnSpacing="10">
                                            <Label Text="{Binding Icon}" FontSize="22"
                                                   VerticalOptions="Center"/>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding DisplayName}"
                                                       FontSize="14" FontAttributes="Bold"
                                                       TextColor="{StaticResource TextPrimary}"/>
                                                <Label Text="{Binding DisplayPrice}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource Primary}"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding CountText}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center"
                                                   MinimumWidthRequest="28"
                                                   HorizontalOptions="Center"/>
                                            <Frame Grid.Column="3"
                                                   WidthRequest="36" HeightRequest="36"
                                                   CornerRadius="18"
                                                   BackgroundColor="{StaticResource Primary}"
                                                   BorderColor="Transparent"
                                                   Padding="0" HasShadow="False">
                                                <Label Text="+" FontSize="20" TextColor="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Tapped="AddAddon_Tapped"
                                                            CommandParameter="{Binding Id}"/>
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Frame>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- Price Breakdown -->
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="PriceDetailsLabel" Text="Hinna ülevaade"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Frame BackgroundColor="{StaticResource SecondaryBackground}"
                               CornerRadius="14" Padding="16" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="NightsLabel" Style="{StaticResource MutedLabel}"/>
                                    <Label x:Name="SubtotalLabel" Grid.Column="1"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="AddonsHeaderPriceLabel" Text="Lisateenused"
                                           Style="{StaticResource MutedLabel}"/>
                                    <Label x:Name="AddonsLabel" Grid.Column="1"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" Text="€0"/>
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource Border}"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="TotalHeaderLabel" Text="Kokku"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    <Label x:Name="TotalLabel" Grid.Column="1"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Cancellation Policy -->
                    <Frame BackgroundColor="{StaticResource SecondaryBackground}"
                           CornerRadius="14" Padding="16" BorderColor="Transparent">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="CancellationLabel" Text="Tühistamispoliitika"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✓" TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold"/>
                                <Label Text="Tasuta tühistamine 48h enne saabumist"
                                       Style="{StaticResource MutedLabel}" FontSize="13"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✓" TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold"/>
                                <Label Text="Kontakt: +372 5500 075"
                                       Style="{StaticResource MutedLabel}" FontSize="13"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <BoxView HeightRequest="8"/>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom confirm button -->
        <Grid Grid.Row="1" Padding="20,12"
              BackgroundColor="{StaticResource CardBackground}">
            <BoxView HeightRequest="1"
                     BackgroundColor="{StaticResource Border}"
                     VerticalOptions="Start"/>
            <Button x:Name="ConfirmButton"
                    Text="Kinnita broneering"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Clicked="Confirm_Clicked"
                    Margin="0,4,0,0"/>
        </Grid>

    </Grid>
</ContentPage>
