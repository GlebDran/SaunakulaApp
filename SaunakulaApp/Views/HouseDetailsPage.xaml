<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SaunakulaApp.Views.HouseDetailsPage"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- Photo Gallery -->
                <Grid HeightRequest="300">
                    <CollectionView x:Name="PhotoGallery"
                                    HeightRequest="300"
                                    HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               SnapPointsType="MandatorySingle"
                                               SnapPointsAlignment="Center"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding .}"
                                       Aspect="AspectFill"
                                       WidthRequest="400"
                                       HeightRequest="300"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <BoxView VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Back button -->
                    <Frame WidthRequest="40" HeightRequest="40"
                           CornerRadius="20"
                           BackgroundColor="#EEFFFFFF"
                           BorderColor="Transparent"
                           Padding="0" Margin="16,48,0,0"
                           HorizontalOptions="Start" VerticalOptions="Start"
                           HasShadow="False">
                        <Label Text="&#8249;" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Back_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Frame>

                    <!-- Favourite button -->
                    <Frame WidthRequest="40" HeightRequest="40"
                           CornerRadius="20"
                           BackgroundColor="#EEFFFFFF"
                           BorderColor="Transparent"
                           Padding="0" Margin="0,48,16,0"
                           HorizontalOptions="End" VerticalOptions="Start"
                           HasShadow="False">
                        <Label x:Name="FavLabel" Text="🤍" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Favourite_Tapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Frame>

                    <HorizontalStackLayout x:Name="DotsLayout"
                                           HorizontalOptions="Center"
                                           VerticalOptions="End"
                                           Spacing="6" Margin="0,0,0,14"/>
                </Grid>

                <!-- Content -->
                <VerticalStackLayout Padding="20,20" Spacing="20">

                    <!-- Title + Rating -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="TitleLabel"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="📍" FontSize="13"/>
                                <Label x:Name="LocationAddressLabel"
                                       Text="Saue vald, Harjumaa"
                                       Style="{StaticResource MutedLabel}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="⭐" FontSize="13"/>
                                <Label Text="4.9" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"/>
                                <Label Text="(48)" Style="{StaticResource MutedLabel}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Quick Info Cards -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                        <Frame Grid.Column="0"
                               BackgroundColor="{StaticResource SecondaryBackground}"
                               CornerRadius="12" Padding="10" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="👥" FontSize="18" HorizontalOptions="Center"/>
                                <Label x:Name="GuestsUntilLabel"
                                       Text="Kuni" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="GuestsLabel"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame Grid.Column="1"
                               BackgroundColor="{StaticResource SecondaryBackground}"
                               CornerRadius="12" Padding="10" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="📐" FontSize="18" HorizontalOptions="Center"/>
                                <Label x:Name="SizeHeaderLabel"
                                       Text="Suurus" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="SizeLabel"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame Grid.Column="2"
                               BackgroundColor="{StaticResource SecondaryBackground}"
                               CornerRadius="12" Padding="10" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="⏱" FontSize="18" HorizontalOptions="Center"/>
                                <Label x:Name="MinTimeLabel"
                                       Text="Min aeg" FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="MinHoursLabel"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                    </Grid>

                    <!-- Description -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="DescriptionHeaderLabel"
                               Text="Kirjeldus"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Label x:Name="DescLabel"
                               Style="{StaticResource MutedLabel}"
                               LineBreakMode="WordWrap" LineHeight="1.5"/>
                    </VerticalStackLayout>

                    <!-- Amenities -->
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="AmenitiesHeaderLabel"
                               Text="Mugavused"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <CollectionView x:Name="AmenitiesView">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="2"
                                                 HorizontalItemSpacing="8"
                                                 VerticalItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="8" Padding="0,4">
                                        <Frame WidthRequest="28" HeightRequest="28"
                                               CornerRadius="14"
                                               BackgroundColor="{StaticResource PrimaryExtraLight}"
                                               BorderColor="Transparent" Padding="0">
                                            <Label Text="✓" FontSize="12"
                                                   TextColor="{StaticResource Primary}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Frame>
                                        <Label Text="{Binding .}" FontSize="13"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- Pricing -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="PricingHeaderLabel"
                               Text="Hinnakiri"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Frame BackgroundColor="{StaticResource SecondaryBackground}"
                               CornerRadius="12" Padding="16" BorderColor="Transparent">
                            <VerticalStackLayout Spacing="10">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="HourlyPriceHeaderLabel"
                                           Text="Tunnihind (4–7h)"
                                           Style="{StaticResource MutedLabel}"/>
                                    <Label x:Name="HourlyPriceLabel"
                                           Grid.Column="1"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"/>
                                </Grid>

                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Border}"/>

                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label x:Name="DayPriceHeaderLabel"
                                           Text="24h hind"
                                           Style="{StaticResource MutedLabel}"/>
                                    <Label x:Name="RegularPriceLabel"
                                           Grid.Column="1" FontSize="13"
                                           TextColor="{StaticResource TextSecondary}"
                                           TextDecorations="Strikethrough"
                                           Margin="0,0,8,0" VerticalOptions="Center"/>
                                    <Label x:Name="DayPriceLabel"
                                           Grid.Column="2"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}"/>
                                </Grid>

                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Border}"/>

                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="⏱" FontSize="13"/>
                                    <Label x:Name="MinHoursNoteLabel"
                                           Text="Minimaalne broneerimisaeg 4h"
                                           Style="{StaticResource MutedLabel}"
                                           FontSize="12" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Location Map -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="LocationHeaderLabel"
                               Text="Asukoht"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Frame CornerRadius="14" Padding="0"
                               BorderColor="{StaticResource Border}"
                               HasShadow="False" HeightRequest="200"
                               IsClippedToBounds="True">
                            <WebView x:Name="MapView" HeightRequest="200"/>
                        </Frame>
                        <Button x:Name="OpenMapsButton"
                                Text="🗺  Ava Google Maps"
                                Style="{StaticResource SecondaryButton}"
                                HeightRequest="46"
                                Clicked="OpenMaps_Clicked"/>
                    </VerticalStackLayout>

                    <!-- Contact -->
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="ContactHeaderLabel"
                               Text="Kontakt"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>
                        <Frame Style="{StaticResource Card}" Padding="0">
                            <VerticalStackLayout Spacing="0">

                                <!-- Call -->
                                <Grid ColumnDefinitions="44,*,Auto"
                                      Padding="16,14" ColumnSpacing="8">
                                    <Frame WidthRequest="36" HeightRequest="36"
                                           CornerRadius="18"
                                           BackgroundColor="{StaticResource PrimaryExtraLight}"
                                           BorderColor="Transparent" Padding="0">
                                        <Label Text="📞" FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center" Spacing="2">
                                        <Label x:Name="CallLabel"
                                               Text="Helista"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="+372 5500 075" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{StaticResource TextSecondary}"
                                           VerticalOptions="Center"/>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="Call_Tapped"/>
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Border}"
                                         Margin="16,0"/>

                                <!-- Email -->
                                <Grid ColumnDefinitions="44,*,Auto"
                                      Padding="16,14" ColumnSpacing="8">
                                    <Frame WidthRequest="36" HeightRequest="36"
                                           CornerRadius="18"
                                           BackgroundColor="{StaticResource PrimaryExtraLight}"
                                           BorderColor="Transparent" Padding="0">
                                        <Label Text="✉️" FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center" Spacing="2">
                                        <Label x:Name="EmailLabel"
                                               Text="Saada e-kiri"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="sauna@saunamaailm.ee" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{StaticResource TextSecondary}"
                                           VerticalOptions="Center"/>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="Email_Tapped"/>
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Border}"
                                         Margin="16,0"/>

                                <!-- Instagram -->
                                <Grid ColumnDefinitions="44,*,Auto"
                                      Padding="16,14" ColumnSpacing="8">
                                    <Frame WidthRequest="36" HeightRequest="36"
                                           CornerRadius="18"
                                           BackgroundColor="{StaticResource PrimaryExtraLight}"
                                           BorderColor="Transparent" Padding="0">
                                        <Label Text="📸" FontSize="16"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center" Spacing="2">
                                        <Label Text="Instagram"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"/>
                                        <Label Text="@sauna.kula" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           TextColor="{StaticResource TextSecondary}"
                                           VerticalOptions="Center"/>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="Instagram_Tapped"/>
                                    </Grid.GestureRecognizers>
                                </Grid>

                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="20"/>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Bar -->
        <Grid Grid.Row="1" Padding="20,12"
              BackgroundColor="{StaticResource CardBackground}">
            <BoxView HeightRequest="1"
                     BackgroundColor="{StaticResource Border}"
                     VerticalOptions="Start"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,4,0,0">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label x:Name="BottomPriceHeaderLabel"
                           Text="Hind 24h"
                           Style="{StaticResource MutedLabel}"
                           FontSize="12"/>
                    <Label x:Name="BottomPriceLabel"
                           FontSize="24" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"/>
                </VerticalStackLayout>
                <Button x:Name="BookButton"
                        Grid.Column="1"
                        Text="Broneeri"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalOptions="FillAndExpand"
                        Clicked="Book_Clicked"/>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
