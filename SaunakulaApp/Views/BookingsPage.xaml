<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SaunakulaApp.Views.BookingsPage"
    Shell.NavBarIsVisible="False">

    <VerticalStackLayout Spacing="0">

        <!-- Header -->
        <VerticalStackLayout Padding="20,52,20,16"
                             BackgroundColor="{StaticResource Background}">
            <Label x:Name="PageTitleLabel"
                   Text="Minu broneerimine"
                   Style="{StaticResource TitleLabel}"/>
            <Label x:Name="PageSubtitleLabel"
                   Text="Halda oma broneeringuid"
                   Style="{StaticResource MutedLabel}"
                   Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <!-- Tabs -->
        <Grid ColumnDefinitions="*,*"
              Margin="20,0,20,16"
              BackgroundColor="{StaticResource SecondaryBackground}"
              HeightRequest="44">
            <Frame Grid.Column="0" x:Name="UpcomingTab"
                   BackgroundColor="{StaticResource CardBackground}"
                   CornerRadius="10" Margin="4" Padding="0"
                   BorderColor="Transparent" HasShadow="True">
                <Label x:Name="UpcomingTabLabel"
                       Text="Tulevased"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="UpcomingTab_Tapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Frame>
            <Frame Grid.Column="1" x:Name="PastTab"
                   BackgroundColor="Transparent"
                   CornerRadius="10" Margin="4" Padding="0"
                   BorderColor="Transparent" HasShadow="False">
                <Label x:Name="PastTabLabel"
                       Text="Varasemad"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="PastTab_Tapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </Frame>
        </Grid>

        <!-- Not logged in -->
        <VerticalStackLayout x:Name="NotLoggedInView"
                             IsVisible="False"
                             VerticalOptions="CenterAndExpand"
                             HorizontalOptions="Center"
                             Spacing="16" Padding="40">
            <Label Text="🔒" FontSize="52" HorizontalOptions="Center"/>
            <Label x:Name="NotLoggedInLabel"
                   Text="Logi sisse, et näha broneeringuid"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Button x:Name="LoginButton"
                    Text="Logi sisse"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="Login_Clicked"/>
        </VerticalStackLayout>

        <!-- Empty state -->
        <VerticalStackLayout x:Name="EmptyView"
                             IsVisible="False"
                             VerticalOptions="CenterAndExpand"
                             HorizontalOptions="Center"
                             Spacing="12" Padding="40">
            <Label Text="📅" FontSize="52" HorizontalOptions="Center"/>
            <Label x:Name="EmptyTitleLabel"
                   Text="Broneeringuid pole"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center"/>
            <Label x:Name="EmptySubLabel"
                   Text="Alusta oma järgmise puhkuse planeerimist!"
                   Style="{StaticResource MutedLabel}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
            <Button x:Name="BrowseButton"
                    Text="Vaata maju"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="Browse_Clicked"/>
        </VerticalStackLayout>

        <!-- Bookings list -->
        <CollectionView x:Name="BookingsView" Margin="20,0,20,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,0,0,16">
                        <Frame Style="{StaticResource Card}" Padding="0">
                            <VerticalStackLayout Spacing="0">

                                <Grid ColumnDefinitions="110,*">
                                    <Image Source="{Binding HouseImage}"
                                           Aspect="AspectFill"
                                           HeightRequest="110" WidthRequest="110"/>
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="14,12" Spacing="5"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding HouseTitle}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📍" FontSize="11"/>
                                            <Label Text="Saue vald, Harjumaa"
                                                   Style="{StaticResource MutedLabel}"
                                                   FontSize="12"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📅" FontSize="11"/>
                                            <Label Text="{Binding DateRange}"
                                                   Style="{StaticResource MutedLabel}"
                                                   FontSize="12"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="👥" FontSize="11"/>
                                            <Label Text="{Binding GuestText}"
                                                   Style="{StaticResource MutedLabel}"
                                                   FontSize="12"/>
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding TotalText}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               Margin="0,4,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <BoxView HeightRequest="1"
                                         BackgroundColor="{StaticResource Border}"/>
                                <Grid Padding="14,10" ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding StatusText}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{Binding StatusColor}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding CancelText}"
                                           FontSize="13"
                                           TextColor="{StaticResource Destructive}"
                                           IsVisible="{Binding CanCancel}"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Tapped="Cancel_Tapped"
                                                CommandParameter="{Binding Id}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>

                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
