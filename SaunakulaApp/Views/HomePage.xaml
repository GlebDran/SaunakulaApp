<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SaunakulaApp.Views.HomePage"
    Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid Padding="20,52,20,16" ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="GreetingLabel"
                           Text="Tere tulemast! 👋"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"/>
                    <Label x:Name="HomeTitleLabel"
                           Text="Mõnus saunapuhkus"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>
                    <Label x:Name="HomeSubtitleLabel"
                           Text="Saue vald · vähem kui 10 km Tallinnast"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}"/>
                </VerticalStackLayout>
                <Frame Grid.Column="1"
                       WidthRequest="44" HeightRequest="44"
                       CornerRadius="22"
                       BackgroundColor="{StaticResource PrimaryExtraLight}"
                       BorderColor="Transparent"
                       Padding="0"
                       VerticalOptions="Center"
                       HasShadow="False">
                    <Label x:Name="AvatarLabel"
                           Text="👤"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Avatar_Tapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Frame>
            </Grid>

            <!-- PäevaSPA promo banner -->
            <Frame Margin="20,0,20,20"
                   CornerRadius="16" Padding="14,12"
                   BorderColor="Transparent" HasShadow="False">
                <Frame.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#5A7C5E" Offset="0"/>
                        <GradientStop Color="#3D5C41" Offset="1"/>
                    </LinearGradientBrush>
                </Frame.Background>
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="3">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🌿" FontSize="14"/>
                            <Label Text="PäevaSPA -40%"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                        <Label Text="E–N kl 10:00–17:00 · Jahimehe &amp; Vene maja"
                               FontSize="11" TextColor="#CCFFFFFF"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="57€/h"
                           FontSize="20" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center"/>
                </Grid>
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="PromoBanner_Tapped"/>
                </Frame.GestureRecognizers>
            </Frame>

            <!-- Categories -->
            <Label x:Name="ActivitiesLabel"
                   Text="Vali tegevus"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="20,0,20,12"/>

            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Margin="20,0,0,20">
                <HorizontalStackLayout Spacing="10">

                    <Frame x:Name="CatAll" CornerRadius="20" Padding="14,8"
                           BackgroundColor="{StaticResource Primary}"
                           BorderColor="Transparent" HasShadow="False">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🏠" FontSize="14"/>
                            <Label Text="Kõik" FontSize="13" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="CatAll_Tapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame x:Name="CatSaun" CornerRadius="20" Padding="14,8"
                           BackgroundColor="{StaticResource SecondaryBackground}"
                           BorderColor="Transparent" HasShadow="False">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🔥" FontSize="14"/>
                            <Label Text="Saun" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="CatSaun_Tapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame x:Name="CatBassein" CornerRadius="20" Padding="14,8"
                           BackgroundColor="{StaticResource SecondaryBackground}"
                           BorderColor="Transparent" HasShadow="False">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="💧" FontSize="14"/>
                            <Label Text="Bassein" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="CatBassein_Tapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame x:Name="CatKaraoke" CornerRadius="20" Padding="14,8"
                           BackgroundColor="{StaticResource SecondaryBackground}"
                           BorderColor="Transparent" HasShadow="False">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="🎤" FontSize="14"/>
                            <Label Text="Karaoke" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="CatKaraoke_Tapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame x:Name="CatSuur" CornerRadius="20" Padding="14,8"
                           BackgroundColor="{StaticResource SecondaryBackground}"
                           BorderColor="Transparent" HasShadow="False">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="👥" FontSize="14"/>
                            <Label Text="Suur grupp" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="CatSuur_Tapped"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- Featured house -->
            <Label x:Name="FeaturedLabel"
                   Text="Külaliste lemmik"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="20,0,20,12"/>

            <Frame Style="{StaticResource Card}"
                   Margin="20,0,20,24" Padding="0">
                <Grid RowDefinitions="220,Auto">

                    <Image x:Name="FeaturedImage"
                           Aspect="AspectFill" HeightRequest="220"/>

                    <BoxView VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <Frame HorizontalOptions="Start" VerticalOptions="Start"
                           Margin="12,12,0,0" CornerRadius="12"
                           BackgroundColor="#5A7C5E"
                           BorderColor="Transparent"
                           Padding="8,4" HasShadow="False">
                        <Label x:Name="FeaturedBadgeLabel"
                               Text="⭐ Külaliste lemmik"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="White"/>
                    </Frame>

                    <VerticalStackLayout VerticalOptions="End"
                                         HorizontalOptions="End"
                                         Margin="0,0,12,12" Spacing="0">
                        <Label x:Name="FeaturedPrice"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="End"/>
                        <Label Text="/24h" FontSize="11"
                               TextColor="#CCFFFFFF" HorizontalOptions="End"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Row="1" Padding="14,12" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label x:Name="FeaturedTitle"
                                       FontSize="18" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="📍" FontSize="12"/>
                                    <Label Text="Saue vald, Harjumaa"
                                           Style="{StaticResource MutedLabel}"
                                           FontSize="12" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="4"
                                                   VerticalOptions="Center">
                                <Label Text="👥" FontSize="12"/>
                                <Label x:Name="FeaturedGuests"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Button x:Name="FeaturedDetailsButton"
                                    Text="Vaata lähemalt"
                                    Style="{StaticResource SecondaryButton}"
                                    HeightRequest="44"
                                    Clicked="FeaturedDetails_Clicked"/>
                            <Button x:Name="FeaturedBookButton"
                                    Grid.Column="1"
                                    Text="Broneeri"
                                    Style="{StaticResource PrimaryButton}"
                                    HeightRequest="44"
                                    Clicked="FeaturedBook_Clicked"/>
                        </Grid>
                    </VerticalStackLayout>

                </Grid>
            </Frame>

            <!-- All houses list -->
            <Label x:Name="AllHousesLabel"
                   Text="Kõik majad"
                   FontSize="16" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="20,0,20,12"/>

            <CollectionView x:Name="HousesView"
                            Margin="20,0,20,32"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource Card}"
                               Padding="0" Margin="0,0,0,14">
                            <Grid ColumnDefinitions="120,*">
                                <Image Source="{Binding Image}"
                                       Aspect="AspectFill"
                                       WidthRequest="120"
                                       HeightRequest="120"/>
                                <VerticalStackLayout Grid.Column="1"
                                                     Padding="12,10"
                                                     Spacing="5"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding DisplayTitle}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation"/>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="👥" FontSize="11"/>
                                        <Label Text="{Binding GuestsText}"
                                               Style="{StaticResource MutedLabel}"
                                               FontSize="12" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="⭐" FontSize="11"/>
                                        <Label Text="4.9"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <Label Text="{Binding DisplayPrice}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               VerticalOptions="Center"/>
                                        <Button Grid.Column="1"
                                                Text="{Binding ViewButtonText}"
                                                Style="{StaticResource PrimaryButton}"
                                                HeightRequest="34"
                                                FontSize="12"
                                                Padding="12,0"
                                                CommandParameter="{Binding HouseId}"
                                                Clicked="HouseDetails_Clicked"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
