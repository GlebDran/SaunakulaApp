<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="SaunakulaApp.Views.LoginPage"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="28,60,28,28" Spacing="0">

            <!-- Logo / Title -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,48">
                <Label Text="🌲"
                       FontSize="52"
                       HorizontalOptions="Center"/>
                <Label Text="Saunaküla"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center"/>
                <Label Text="Tere tulemast tagasi!"
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Email -->
            <Label Text="E-post"
                   FontSize="14" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="0,0,0,6"/>
            <Frame CornerRadius="14"
                   BackgroundColor="{StaticResource MutedBackground}"
                   BorderColor="Transparent"
                   Padding="16,0"
                   HeightRequest="52"
                   HasShadow="False"
                   Margin="0,0,0,16">
                <Entry x:Name="EmailEntry"
                       Placeholder="sinu@email.ee"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       HeightRequest="52"/>
            </Frame>

            <!-- Password -->
            <Label Text="Parool"
                   FontSize="14" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="0,0,0,6"/>
            <Frame CornerRadius="14"
                   BackgroundColor="{StaticResource MutedBackground}"
                   BorderColor="Transparent"
                   Padding="16,0"
                   HeightRequest="52"
                   HasShadow="False"
                   Margin="0,0,0,8">
                <Entry x:Name="PasswordEntry"
                       Placeholder="••••••••"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       HeightRequest="52"/>
            </Frame>

            <!-- Error message -->
            <Label x:Name="ErrorLabel"
                   TextColor="{StaticResource Destructive}"
                   FontSize="13"
                   IsVisible="False"
                   Margin="0,0,0,16"/>

            <!-- Login Button -->
            <Button Text="Logi sisse"
                    Style="{StaticResource PrimaryButton}"
                    Clicked="Login_Clicked"
                    Margin="0,16,0,0"/>

            <!-- Divider -->
            <Grid ColumnDefinitions="*,Auto,*"
                  ColumnSpacing="12"
                  Margin="0,24,0,24">
                <BoxView BackgroundColor="{StaticResource Border}"
                         HeightRequest="1"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="või"
                       Style="{StaticResource MutedLabel}"/>
                <BoxView Grid.Column="2"
                         BackgroundColor="{StaticResource Border}"
                         HeightRequest="1"
                         VerticalOptions="Center"/>
            </Grid>

            <!-- Register link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Pole kontot?"
                       Style="{StaticResource MutedLabel}"/>
                <Label Text="Registreeru"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{StaticResource Primary}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="GoToRegister_Tapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>